kernaddr=0x80008000
fdtaddr=0x80C00000
fdtovaddr=0x80D00000
envtxtaddr=0x80E00000

# TF卡启动配置
loadconfig=fatload mmc 0:1 ${envtxtaddr} /sys-config.conf; env import -t ${envtxtaddr};
loadbasic=fatload mmc 0:1 ${kernaddr} /${kernelfn}; fatload mmc 0:1 ${fdtaddr} /dt/devicetree-${device_rev}.dtb; fatload mmc 0:1 ${fdtovaddr} /dt/screen/${screen}.dtbo;
patchbasic=fdt addr $fdtaddr; fdt resize 32768; fdt apply $fdtovaddr;
patchinterface=for ov in ${interface}; do echo Applying Interface ${ov}...; fatload mmc 0:1 ${fdtovaddr} "/dt/interface/${ov}.dtbo"; fdt apply ${fdtovaddr}; done;
patchext=for ov in ${ext}; do echo Applying extension ${ov}...; fatload mmc 0:1 ${fdtovaddr} "/dt/ext/${ov}.dtbo"; fdt apply ${fdtovaddr}; done;

distro_bootcmd=run loadconfig; run loadbasic; run patchbasic; run patchinterface; run patchext; bootz $kernaddr - $fdtaddr;